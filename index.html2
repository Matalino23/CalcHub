      <button class="action-btn" onclick="calcMileage()">Calculate</button>

      <div class="result-box" id="mi-result">
        <div class="breakdown" style="margin-top:0;padding-top:0;border-top:none">
          <div class="brow"><span>⛽ Fuel Cost</span><span id="mi-fuel">—</span></div>
          <div class="brow"><span>📋 HMRC Mileage Claim</span><span id="mi-claim" style="color:var(--green)">—</span></div>
          <div class="brow" style="padding-top:0.45rem;border-top:0.5px solid var(--sep)">
            <span>💰 Net Claim Profit</span><span id="mi-profit" style="color:var(--blue)">—</span>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /card -->
</div><!-- /hub -->

<script>
/* ─── TABS ──────────────────────────────────────────────── */
function switchTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  btn.classList.add('active');
}

/* ─── BASIC CALCULATOR ──────────────────────────────────── */
const S = { current: '0', prev: null, op: null, exprParts: [], fresh: false };
const SYM = { '+':'+', '-':'−', '*':'×', '/':'÷' };

function renderScreen() {
  const numEl  = document.getElementById('b-num');
  const exprEl = document.getElementById('b-expr');
  numEl.textContent = S.current;
  if (S.exprParts.length === 0) {
    exprEl.innerHTML = '&nbsp;';
  } else {
    exprEl.innerHTML = S.exprParts.map(t => {
      const isOp = ['+','−','×','÷','='].includes(t);
      return isOp ? `<span class="op-token">${t}</span>` : t;
    }).join(' ');
  }
  // Auto-shrink large numbers
  const len = S.current.length;
  numEl.style.fontSize = len > 9 ? 'clamp(1.8rem,8vw,2.6rem)' : len > 6 ? 'clamp(2.4rem,11vw,3.8rem)' : '';
}

function bNum(d) {
  if (S.fresh) { S.current = d; S.fresh = false; }
  else if (S.current === '0') S.current = d;
  else if (S.current.replace(/[^0-9]/g,'').length < 12) S.current += d;
  renderScreen();
}
function bDot() {
  if (S.fresh) { S.current = '0.'; S.fresh = false; }
  else if (!S.current.includes('.')) S.current += '.';
  renderScreen();
}
function bBack() {
  if (S.fresh || S.current.length <= 1) { S.current = '0'; S.fresh = false; }
  else S.current = S.current.slice(0, -1) || '0';
  renderScreen();
}
function bOp(op) {
  if (S.op !== null && !S.fresh) {
    const res = compute(parseFloat(S.prev), parseFloat(S.current), S.op);
    S.exprParts.push(S.current, SYM[op]);
    S.current = fmtNum(res);
    S.prev = res;
  } else {
    S.exprParts.push(S.current, SYM[op]);
    S.prev = parseFloat(S.current);
  }
  S.op = op; S.fresh = true;
  renderScreen();
}
function bEquals() {
  if (S.op === null) return;
  const res = compute(parseFloat(S.prev), parseFloat(S.current), S.op);
  S.exprParts.push(S.current, '=');
  S.current = fmtNum(res);
  S.op = null; S.prev = null; S.fresh = true;
  renderScreen();
}
function bClear() {
  S.current = '0'; S.prev = null; S.op = null; S.exprParts = []; S.fresh = false;
  renderScreen();
}
function bSign() {
  const n = parseFloat(S.current);
  if (!isNaN(n)) { S.current = fmtNum(n * -1); renderScreen(); }
}
function bPercent() {
  const n = parseFloat(S.current);
  if (!isNaN(n)) { S.current = fmtNum(n / 100); renderScreen(); }
}
function compute(a, b, op) {
  if (op === '+') return a + b;
  if (op === '-') return a - b;
  if (op === '*') return a * b;
  if (op === '/') return b === 0 ? NaN : a / b;
}
function fmtNum(n) {
  if (isNaN(n) || !isFinite(n)) return 'Error';
  if (Number.isInteger(n)) return String(n);
  return parseFloat(n.toFixed(10)).toString();
}

/* ─── SALARY ────────────────────────────────────────────── */
function money(n) {
  return '£' + n.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function toggleLoanInfo(btn) {
  btn.classList.toggle('open');
  btn.nextElementSibling.classList.toggle('open');
}

function updateSalarySubtitle() {
  const val = parseFloat(document.getElementById('s-gross').value);
  const el  = document.getElementById('s-subtitle');
  if (!val || val <= 0) {
    el.innerHTML = 'Enter your salary above to see the breakdown.';
  } else {
    el.innerHTML = `I want to see the breakdown for a salary of <strong>${money(val)}</strong>`;
  }
}

function parseTaxCode(code, defaultPA) {
  defaultPA = defaultPA || 12570;
  const c = (code || '1257L').toUpperCase().trim();
  if (c === 'BR')  return { pa: 0, flatRate: 0.20 };
  if (c === 'D0')  return { pa: 0, flatRate: 0.40 };
  if (c === 'D1')  return { pa: 0, flatRate: 0.45 };
  if (c === 'NT')  return { pa: 999999, flatRate: null };
  if (c === '0T')  return { pa: 0, flatRate: null };
  const kMatch = c.match(/^K(\d+)$/);
  if (kMatch) return { pa: -(parseInt(kMatch[1]) * 10), flatRate: null };
  const lMatch = c.match(/^(\d+)[LMNTYW]?$/);
  if (lMatch) return { pa: parseInt(lMatch[1]) * 10, flatRate: null };
  return { pa: defaultPA, flatRate: null };
}

function calcIncomeTax(grossAfterSacrifice, taxCode, yr) {
  yr = yr || TAX_YEARS['2425'];
  const { pa, flatRate } = parseTaxCode(taxCode, yr.pa);
  if (flatRate !== null) return { tax: grossAfterSacrifice * flatRate, personalAllowance: 0 };

  // Taper personal allowance above £100,000
  let personalAllowance = pa;
  if (grossAfterSacrifice > 100000 && pa > 0) {
    personalAllowance = Math.max(0, pa - Math.floor((grossAfterSacrifice - 100000) / 2));
  }

  const taxable    = Math.max(0, grossAfterSacrifice - personalAllowance);
  const basicBand  = yr.basicBand;
  const higherBand = yr.higherTop - yr.pa - basicBand;

  let tax = 0;
  if (taxable <= basicBand) {
    tax = taxable * 0.20;
  } else if (taxable <= basicBand + higherBand) {
    tax = basicBand * 0.20 + (taxable - basicBand) * 0.40;
  } else {
    tax = basicBand * 0.20 + higherBand * 0.40 + (taxable - basicBand - higherBand) * 0.45;
  }

  return { tax, personalAllowance };
}

// Tax year data — NI rates: niMain = PT→UEL, niHigh = above UEL
const TAX_YEARS = {
  '2627': {
    label: '2026/27',
    pa: 12570, basicBand: 37700, higherTop: 125140,
    niPT: 12570, niUEL: 50270, niMain: 0.08, niHigh: 0.02,
    loanThresholds: { '1': 26065, '2': 28470, '4': 32745, '5': 25000, 'pg': 21000 }
  },
  '2526': {
    label: '2025/26',
    pa: 12570, basicBand: 37700, higherTop: 125140,
    niPT: 12570, niUEL: 50270, niMain: 0.08, niHigh: 0.02,
    loanThresholds: { '1': 26065, '2': 28470, '4': 32745, '5': 25000, 'pg': 21000 }
  },
  '2425': {
    label: '2024/25',
    pa: 12570, basicBand: 37700, higherTop: 125140,
    niPT: 12570, niUEL: 50270, niMain: 0.08, niHigh: 0.02,
    loanThresholds: { '1': 24990, '2': 27295, '4': 31395, '5': 25000, 'pg': 21000 }
  },
  '2324': {
    label: '2023/24',
    pa: 12570, basicBand: 37700, higherTop: 125140,
    niPT: 12570, niUEL: 50270, niMain: 0.12, niHigh: 0.02,
    loanThresholds: { '1': 22015, '2': 27295, '4': 27660, '5': null,  'pg': 21000 }
  },
  '2223': {
    label: '2022/23',
    pa: 12570, basicBand: 37700, higherTop: 150000,
    niPT: 12570, niUEL: 50270, niMain: 0.12, niHigh: 0.02,
    loanThresholds: { '1': 20195, '2': 27295, '4': 25375, '5': null,  'pg': 21000 }
  }
};

function calcNI(niableGross, yr) {
  const { niPT, niUEL, niMain, niHigh } = yr;
  if (niableGross <= niPT) return 0;
  if (niableGross <= niUEL) return (niableGross - niPT) * niMain;
  return (niUEL - niPT) * niMain + (niableGross - niUEL) * niHigh;
}

function toAnnual(val, period) {
  if (!val || isNaN(val)) return 0;
  if (period === 'month') return val * 12;
  if (period === 'week')  return val * 52;
  return val;
}

function calcSalary() {
  const gross       = parseFloat(document.getElementById('s-gross').value);
  const freq        = parseInt(document.getElementById('s-freq').value);
  const taxCode     = document.getElementById('s-taxcode').value || '1257L';
  const loan        = document.getElementById('s-loan').value;
  const pensionPct  = (parseFloat(document.getElementById('s-pension').value) || 0) / 100;
  const childcare   = (parseFloat(document.getElementById('s-childcare').value) || 0) * 12;
  const yearKey     = document.getElementById('s-taxyear').value;
  const yr          = TAX_YEARS[yearKey] || TAX_YEARS['2425'];

  // Salary sacrifice
  const sacTaxAmt = toAnnual(parseFloat(document.getElementById('s-sac-tax-amt').value), document.getElementById('s-sac-tax-per').value);
  const sacNiAmt  = toAnnual(parseFloat(document.getElementById('s-sac-ni-amt').value),  document.getElementById('s-sac-ni-per').value);

  if (!gross || gross <= 0) return alert('Enter a valid gross salary.');

  // Tax exempt sacrifice + pension + childcare all reduce taxable gross
  const pensionAmt   = gross * pensionPct;
  const taxableGross = Math.max(0, gross - pensionAmt - childcare - sacTaxAmt);

  // Income tax using tax code + year-specific UK bands
  const { tax, personalAllowance } = calcIncomeTax(taxableGross, taxCode, yr);

  // Student loan — use year-specific thresholds
  const thresholds = yr.loanThresholds;
  const loanRates  = { '1': 0.09, '2': 0.09, '4': 0.09, '5': 0.09, 'pg': 0.06 };
  let loanAmt = 0;
  if (loan !== 'none' && thresholds[loan]) {
    loanAmt = Math.max(0, gross - thresholds[loan]) * loanRates[loan];
  }

  // NI — calculated on gross minus ALL sacrifice (tax-exempt and NI-only)
  const niableGross = Math.max(0, gross - pensionAmt - childcare - sacTaxAmt - sacNiAmt);
  const ni = calcNI(niableGross, yr);

  const net = gross - pensionAmt - childcare - sacTaxAmt - sacNiAmt - tax - ni - loanAmt;

  // Render
  document.getElementById('s-net').textContent       = money(net);
  document.getElementById('s-b-gross').textContent   = money(gross);
  document.getElementById('s-b-pa').textContent      = money(personalAllowance);
  document.getElementById('s-b-tax').textContent     = '− ' + money(tax);
  document.getElementById('s-b-ni').textContent      = '− ' + money(ni);
  document.getElementById('s-b-period').textContent  = money(net / freq);

  const pensionRow = document.getElementById('s-pension-row');
  if (pensionAmt > 0) {
    document.getElementById('s-b-pension').textContent = '− ' + money(pensionAmt);
    pensionRow.style.display = 'flex';
  } else { pensionRow.style.display = 'none'; }

  const childcareRow = document.getElementById('s-childcare-row');
  if (childcare > 0) {
    document.getElementById('s-b-childcare').textContent = '− ' + money(childcare);
    childcareRow.style.display = 'flex';
  } else { childcareRow.style.display = 'none'; }

  const sacTaxRow = document.getElementById('s-sac-tax-row');
  if (sacTaxAmt > 0) {
    document.getElementById('s-b-sac-tax').textContent = '− ' + money(sacTaxAmt);
    sacTaxRow.style.display = 'flex';
  } else { sacTaxRow.style.display = 'none'; }

  const sacNiRow = document.getElementById('s-sac-ni-row');
  if (sacNiAmt > 0) {
    document.getElementById('s-b-sac-ni').textContent = '− ' + money(sacNiAmt);
    sacNiRow.style.display = 'flex';
  } else { sacNiRow.style.display = 'none'; }

  const loanRow = document.getElementById('s-loan-row');
  if (loanAmt > 0) {
    document.getElementById('s-b-loan').textContent = '− ' + money(loanAmt);
    loanRow.style.display = 'flex';
  } else { loanRow.style.display = 'none'; }

  document.getElementById('s-result').classList.add('show');
}

/* ─── CURRENCY+ ──────────────────────────────────────────── */
const ALL_CURRENCIES = [
  ['GBP','British Pound','🇬🇧','£'],
  ['USD','US Dollar','🇺🇸','$'],
  ['EUR','Euro','🇪🇺','€'],
  ['CAD','Canadian Dollar','🇨🇦','CA$'],
  ['AUD','Australian Dollar','🇦🇺','A$'],
  ['JPY','Japanese Yen','🇯🇵','¥'],
  ['CHF','Swiss Franc','🇨🇭','Fr'],
  ['CNY','Chinese Yuan','🇨🇳','¥'],
  ['NZD','NZ Dollar','🇳🇿','NZ$'],
  ['SEK','Swedish Krona','🇸🇪','kr'],
  ['NOK','Norwegian Krone','🇳🇴','kr'],
  ['DKK','Danish Krone','🇩🇰','kr'],
  ['MXN','Mexican Peso','🇲🇽','$'],
  ['BRL','Brazilian Real','🇧🇷','R$'],
  ['INR','Indian Rupee','🇮🇳','₹'],
  ['SGD','Singapore Dollar','🇸🇬','S$'],
  ['HKD','Hong Kong Dollar','🇭🇰','HK$'],
  ['KRW','South Korean Won','🇰🇷','₩'],
  ['ZAR','South African Rand','🇿🇦','R'],
  ['AED','UAE Dirham','🇦🇪','د.إ'],
  ['THB','Thai Baht','🇹🇭','฿'],
  ['TRY','Turkish Lira','🇹🇷','₺'],
  ['PLN','Polish Zloty','🇵🇱','zł'],
  ['SAR','Saudi Riyal','🇸🇦','﷼'],
  ['ILS','Israeli Shekel','🇮🇱','₪'],
  ['QAR','Qatari Riyal','🇶🇦','﷼'],
  ['MYR','Malaysian Ringgit','🇲🇾','RM'],
  ['IDR','Indonesian Rupiah','🇮🇩','Rp'],
  ['PKR','Pakistani Rupee','🇵🇰','₨'],
  ['EGP','Egyptian Pound','🇪🇬','E£'],
  ['SOS','Somali Shilling','🇸🇴','Sh'],
];

let cList    = ['GBP','USD','EUR','CAD','AUD'];
let cRates   = {};
let cBase    = 0;
let cBaseAmt = 1;

function getCurrencyMeta(code) {
  return ALL_CURRENCIES.find(c => c[0] === code) || [code, code, '🏳', code];
}
function rebuildAddSelect() {
  const sel = document.getElementById('c-add-select');
  sel.innerHTML = '';
  ALL_CURRENCIES.forEach(([code, name, flag]) => {
    if (!cList.includes(code)) sel.add(new Option(`${flag} ${code} — ${name}`, code));
  });
}
function renderCurrencyList() {
  const container = document.getElementById('c-list');
  container.innerHTML = '';
  cList.forEach((code, i) => {
    const [, name, flag, sym] = getCurrencyMeta(code);
    const isBase = (i === cBase);
    const value  = isBase ? cBaseAmt : convertFromBase(cBaseAmt, code);
    const displayVal = isNaN(value) ? '' : parseFloat(value.toFixed(4));
    const row = document.createElement('div');
    row.className = 'cur-row' + (isBase ? ' base' : '');
    row.innerHTML = `
      <div class="cur-flag-wrap">
        ${flag}
        ${cList.length > 2 ? `<button class="cur-remove" onclick="removeCurrency(${i})" title="Remove">✕</button>` : ''}
      </div>
      <div class="cur-info">
        <span class="cur-name-text">${name}</span>
        <span class="cur-code-text">${code}</span>
      </div>
      <div class="cur-pill${isBase ? ' base' : ''}">
        <span class="cur-pill-sym">${sym}</span>
        <input class="cur-amount-input" type="number" value="${displayVal}"
          placeholder="0" data-index="${i}"
          oninput="onCurInput(this, ${i})"
          onfocus="setBase(${i})">
      </div>
    `;
    row.addEventListener('click', (e) => {
      if (!e.target.classList.contains('cur-amount-input') &&
          !e.target.classList.contains('cur-remove') &&
          !e.target.closest('.cur-remove')) {
        setBase(i); row.querySelector('.cur-amount-input').focus();
      }
    });
    container.appendChild(row);
  });
  rebuildAddSelect();
}
function setBase(i) {
  // Read current displayed value for the newly-selected base
  const inputs = document.querySelectorAll('.cur-amount-input');
  const inputVal = parseFloat(inputs[i]?.value);
  if (!isNaN(inputVal) && inputVal > 0) {
    const code = cList[i];
    if (i === cBase) {
      cBaseAmt = code === 'GBP' ? inputVal : (cRates[code] ? inputVal / cRates[code] : cBaseAmt);
      return; // same row — just update amount, no DOM change needed
    }
    const rateToGBP = code === 'GBP' ? 1 : (cRates[code] ? 1 / cRates[code] : null);
    if (rateToGBP) cBaseAmt = inputVal * rateToGBP;
  } else if (i === cBase) {
    return; // nothing to do
  }

  cBase = i;

  // Update styles in-place — never rebuild the list (avoids destroying focused input)
  const rows = document.querySelectorAll('.cur-row');
  rows.forEach((row, idx) => {
    row.classList.toggle('base', idx === i);
    const pill = row.querySelector('.cur-pill');
    if (pill) pill.classList.toggle('base', idx === i);
    const sym  = row.querySelector('.cur-pill-sym');
    const inp  = row.querySelector('.cur-amount-input');
    if (idx === i) {
      if (sym) sym.style.color = '#FFFFFF';
      if (inp) {
        inp.style.color = '#000000';
        const v = convertFromBase(cBaseAmt, cList[i]);
        if (!isNaN(v)) inp.value = parseFloat(v.toFixed(4));
      }
    } else {
      if (sym) sym.style.color = '#007AFF';
      if (inp) {
        inp.style.color = '#000000';
        const converted = convertFromBase(cBaseAmt, cList[idx]);
        inp.value = isNaN(converted) ? '' : parseFloat(converted.toFixed(4));
      }
    }
  });
}
function onCurInput(input, i) {
  const val = parseFloat(input.value);
  if (isNaN(val)) return;
  cBase = i;
  const code = cList[i];
  cBaseAmt = code === 'GBP' ? val : (cRates[code] ? val / cRates[code] : val);
  const rows = document.querySelectorAll('.cur-row');
  rows.forEach((row, idx) => {
    row.classList.toggle('base', idx === i);
    const pill = row.querySelector('.cur-pill');
    if (pill) pill.classList.toggle('base', idx === i);
    const sym = row.querySelector('.cur-pill-sym');
    if (sym) sym.style.color = '#007AFF';
    if (idx !== i) {
      const inp = row.querySelector('.cur-amount-input');
      const converted = convertFromBase(cBaseAmt, cList[idx]);
      inp.value = isNaN(converted) ? '' : parseFloat(converted.toFixed(4));
      inp.style.color = '#000000';
    } else {
      input.style.color = '#FFFFFF';
    }
  });
}
function convertFromBase(gbpAmt, code) {
  if (code === 'GBP') return gbpAmt;
  const rate = cRates[code];
  return rate ? gbpAmt * rate : NaN;
}
function addCurrency() {
  const sel = document.getElementById('c-add-select');
  const code = sel.value;
  if (!code || cList.includes(code)) return;
  cList.push(code); renderCurrencyList();
  if (!cRates[code]) fetchSingleRate('GBP', code);
}
function removeCurrency(i) {
  if (cList.length <= 2) return;
  cList.splice(i, 1);
  if (cBase >= cList.length) cBase = 0;
  renderCurrencyList();
}
const FALLBACK_RATES = {USD:1.27,EUR:1.17,CAD:1.73,AUD:1.94,JPY:198,CHF:1.12,CNY:9.2,NZD:2.12,SEK:13.5,NOK:13.8,DKK:8.72,MXN:25.4,BRL:7.1,INR:106,SGD:1.71,HKD:9.92,KRW:1740,ZAR:23.5,AED:4.66,THB:44.6,TRY:43,PLN:5.0,SAR:4.76,ILS:4.7,QAR:4.62,MYR:5.9,IDR:20700,PKR:355,EGP:62,SOS:726};

async function refreshAllRates() {
  const btn  = document.getElementById('c-refresh-btn');
  const note = document.getElementById('c-note');
  btn.disabled = true; btn.classList.add('loading');
  btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><path d="M4 4v5h5"/><path d="M20 20v-5h-5"/><path d="M4 9a9 9 0 0 1 15-2.7M20 15a9 9 0 0 1-15 2.7"/></svg> Fetching…`;
  note.textContent = 'Fetching live rates…'; note.className = 'cur-rate-note';
  try {
    // Free open API — no key required, updates every hour
    const res  = await fetch('https://open.er-api.com/v6/latest/GBP');
    const data = await res.json();
    if (data.result !== 'success') throw new Error('API error');
    Object.assign(cRates, data.rates);
    const now = new Date().toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'});
    note.textContent = `Live rates at ${now} · tap a row to set base`;
  } catch(e) {
    note.textContent = 'Could not fetch live rates — using estimates';
    note.className = 'cur-rate-note err';
    Object.assign(cRates, FALLBACK_RATES);
  } finally {
    btn.disabled = false; btn.classList.remove('loading');
    btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><path d="M4 4v5h5"/><path d="M20 20v-5h-5"/><path d="M4 9a9 9 0 0 1 15-2.7M20 15a9 9 0 0 1-15 2.7"/></svg> Refresh Rates`;
    renderCurrencyList();
  }
}

// Auto-fetch on load
(function() { renderCurrencyList(); rebuildAddSelect(); refreshAllRates(); })();

/* ─── STAMP DUTY ────────────────────────────────────────── */
// England & NI rates from 1 April 2025
function sdStandard(p) {
  let d = 0;
  if (p > 1500000) d += (p - 1500000) * 0.12;
  if (p > 925000)  d += (Math.min(p, 1500000) - 925000) * 0.10;
  if (p > 250000)  d += (Math.min(p, 925000)  - 250000) * 0.05;
  if (p > 125000)  d += (Math.min(p, 250000)  - 125000) * 0.02;
  return d;
}
function sdAdditional(p) {
  // Standard + 5% surcharge on every band including zero band
  let d = 0;
  d += Math.min(p, 125000) * 0.05;
  if (p > 125000) d += (Math.min(p, 250000)  - 125000) * 0.07;
  if (p > 250000) d += (Math.min(p, 925000)  - 250000) * 0.10;
  if (p > 925000) d += (Math.min(p, 1500000) - 925000) * 0.15;
  if (p > 1500000) d += (p - 1500000) * 0.17;
  return d;
}
function calcStampDuty() {
  const price = parseFloat(document.getElementById('sd-price').value);
  const type  = document.getElementById('sd-type').value;
  if (!price || price <= 0) return alert('Enter a valid property price.');

  let duty = 0, note = '';
  let bands = [];

  if (type === 'ftb') {
    if (price <= 500000) {
      duty = price > 300000 ? (Math.min(price, 500000) - 300000) * 0.05 : 0;
      note = 'First-time buyer relief applied';
      bands = [
        ['£0 – £300,000','0%', 0],
        ['£300k – £500k','5%', duty],
      ];
    } else {
      duty = sdStandard(price);
      note = 'Above £500k — standard rates, no FTB relief';
      bands = stdBands(price);
    }
  } else if (type === 'additional') {
    duty = sdAdditional(price);
    note = 'Includes 5% additional dwelling surcharge';
    bands = [
      ['£0 – £125,000','5%',  Math.min(price,125000)*0.05],
      ['£125k – £250k','7%',  price>125000?(Math.min(price,250000)-125000)*0.07:0],
      ['£250k – £925k','10%', price>250000?(Math.min(price,925000)-250000)*0.10:0],
      ['£925k – £1.5m','15%', price>925000?(Math.min(price,1500000)-925000)*0.15:0],
      ['£1.5m+','17%',        price>1500000?(price-1500000)*0.17:0],
    ];
  } else {
    duty = sdStandard(price);
    note = 'England & Northern Ireland';
    bands = stdBands(price);
  }

  function stdBands(p) {
    return [
      ['£0 – £125,000','0%', 0],
      ['£125k – £250k','2%', p>125000?(Math.min(p,250000)-125000)*0.02:0],
      ['£250k – £925k','5%', p>250000?(Math.min(p,925000)-250000)*0.05:0],
      ['£925k – £1.5m','10%',p>925000?(Math.min(p,1500000)-925000)*0.10:0],
      ['£1.5m+','12%',       p>1500000?(p-1500000)*0.12:0],
    ];
  }

  const eff = price > 0 ? ((duty/price)*100).toFixed(2) : 0;
  document.getElementById('sd-total').textContent = money(duty);
  document.getElementById('sd-eff').textContent   = `Effective rate: ${eff}% · ${note}`;
  document.getElementById('sd-breakdown').innerHTML = bands
    .filter(([,,v]) => v >= 0)
    .map(([band,rate,v]) => `<div class="brow"><span>${band} <span style="font-size:0.7rem;color:var(--label3)">(${rate})</span></span><span>${money(v)}</span></div>`)
    .join('');
  document.getElementById('sd-result').classList.add('show');
}

/* ─── VAT ───────────────────────────────────────────────── */
function calcVAT() {
  const amount = parseFloat(document.getElementById('v-amount').value);
  const rate   = parseFloat(document.getElementById('v-rate').value) / 100;
  const mode   = document.getElementById('v-mode').value;
  const pct    = Math.round(rate * 100);
  document.getElementById('v-rate-label').textContent = `VAT (${pct}%)`;
  if (!amount || amount <= 0) {
    ['v-net','v-vat','v-gross'].forEach(id => document.getElementById(id).textContent = '—');
    return;
  }
  let net, vat, gross;
  if (mode === 'add') { net = amount; vat = amount * rate; gross = amount + vat; }
  else                { gross = amount; net = amount / (1 + rate); vat = gross - net; }
  document.getElementById('v-net').textContent   = money(net);
  document.getElementById('v-vat').textContent   = money(vat);
  document.getElementById('v-gross').textContent = money(gross);
}

/* ─── MORTGAGE ──────────────────────────────────────────── */
function updateLTV() {
  const price   = parseFloat(document.getElementById('m-price').value);
  const deposit = parseFloat(document.getElementById('m-deposit').value);
  const el = document.getElementById('m-ltv');
  if (price && deposit && price > 0) {
    const ltv = ((price - deposit) / price * 100);
    el.textContent = ltv.toFixed(1) + '%';
    el.style.color = ltv > 90 ? 'var(--red)' : ltv > 75 ? 'var(--orange)' : 'var(--blue)';
  } else { el.textContent = '—'; }
}
function calcMortgage() {
  const price   = parseFloat(document.getElementById('m-price').value);
  const deposit = parseFloat(document.getElementById('m-deposit').value) || 0;
  const annual  = parseFloat(document.getElementById('m-rate').value) / 100;
  const years   = parseInt(document.getElementById('m-term').value);
  const type    = document.getElementById('m-type').value;
  if (!price || !annual || !years) return alert('Fill in property price, interest rate and term.');
  const loan    = price - deposit;
  const months  = years * 12;
  const mr      = annual / 12;
  let monthly, totalPaid, totalInterest;
  if (type === 'interest') {
    monthly = loan * mr;
    totalPaid = monthly * months + loan;
    totalInterest = monthly * months;
  } else {
    monthly = mr === 0 ? loan / months : loan * (mr * Math.pow(1+mr, months)) / (Math.pow(1+mr, months) - 1);
    totalPaid = monthly * months;
    totalInterest = totalPaid - loan;
  }
  document.getElementById('m-monthly').textContent    = money(monthly);
  document.getElementById('m-b-loan').textContent     = money(loan);
  document.getElementById('m-b-interest').textContent = money(totalInterest);
  document.getElementById('m-b-total').textContent    = money(totalPaid);
  document.getElementById('m-result').classList.add('show');
}

/* ─── SAVINGS / ISA ─────────────────────────────────────── */
function calcSavings() {
  const initial = parseFloat(document.getElementById('sv-initial').value) || 0;
  const contrib = parseFloat(document.getElementById('sv-monthly').value) || 0;
  const rate    = parseFloat(document.getElementById('sv-rate').value) / 100;
  const years   = parseInt(document.getElementById('sv-years').value);
  const type    = document.getElementById('sv-type').value;
  if (!years || (!initial && !contrib)) return alert('Enter at least a starting amount or monthly contribution, plus years.');
  const mr = rate / 12;
  let balance = initial;
  for (let i = 0; i < years * 12; i++) { balance = (balance + contrib) * (1 + mr); }
  const totalContrib = initial + contrib * years * 12;
  const interest = balance - totalContrib;
  let bonus = 0;
  if (type === 'lisa') {
    const annualContrib = Math.min(contrib * 12, 4000);
    bonus = annualContrib * 0.25 * years;
    balance += bonus;
  }
  document.getElementById('sv-total').textContent      = money(balance);
  document.getElementById('sv-b-contrib').textContent  = money(totalContrib);
  document.getElementById('sv-b-interest').textContent = '+' + money(interest);
  const bonusRow = document.getElementById('sv-bonus-row');
  if (type === 'lisa' && bonus > 0) {
    document.getElementById('sv-b-bonus').textContent = '+' + money(bonus);
    bonusRow.style.display = 'flex';
  } else { bonusRow.style.display = 'none'; }
  document.getElementById('sv-result').classList.add('show');
}

/* ─── MILEAGE ───────────────────────────────────────────── */
function calcMileage() {
  const miles   = parseFloat(document.getElementById('mi-miles').value);
  const mpg     = parseFloat(document.getElementById('mi-mpg').value);
  const ppl     = parseFloat(document.getElementById('mi-ppl').value);
  const vehicle = document.getElementById('mi-vehicle').value;
  const ytd     = parseFloat(document.getElementById('mi-ytd').value) || 0;
  if (!miles) return alert('Enter distance in miles.');
  // Fuel cost (1 UK gallon = 4.54609 litres)
  const fuelCost = (mpg && ppl) ? miles * (4.54609 / mpg) * (ppl / 100) : null;
  // HMRC claim
  let claim = 0;
  if (vehicle === 'car') {
    const first = Math.max(0, Math.min(miles, Math.max(0, 10000 - ytd)));
    claim = first * 0.45 + (miles - first) * 0.25;
  } else if (vehicle === 'bike') { claim = miles * 0.24; }
  else                           { claim = miles * 0.20; }
  document.getElementById('mi-fuel').textContent  = fuelCost != null ? money(fuelCost) : 'Enter MPG & fuel price';
  document.getElementById('mi-claim').textContent = money(claim);
  document.getElementById('mi-profit').textContent = fuelCost != null ? money(claim - fuelCost) : '—';
  document.getElementById('mi-result').classList.add('show');
}

/* ─── MENU ───────────────────────────────────────────────── */
function toggleMenu() {
  const overlay = document.getElementById('menu-overlay');
  const panel   = document.getElementById('menu-panel');
  const open    = panel.classList.contains('open');
  if (open) {
    panel.classList.remove('open');
    overlay.classList.remove('open');
  } else {
    overlay.classList.add('open');
    panel.classList.add('open');
  }
}
function closeMenu() {
  document.getElementById('menu-panel').classList.remove('open');
  document.getElementById('menu-overlay').classList.remove('open');
}
function menuTab(name) {
  closeMenu();
  // find the tab button with matching text and click it
  const tabs = document.querySelectorAll('.tab-btn');
  tabs.forEach(btn => {
    if (btn.textContent.trim().toLowerCase().includes(name.toLowerCase())) {
      btn.click();
      btn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
  });
}

/* ─── ABOUT ──────────────────────────────────────────────── */
function openAbout() {
  closeMenu();
  document.getElementById('about-overlay').classList.add('open');
}
function closeAbout(e) {
  if (e.target === document.getElementById('about-overlay') || e.target.classList.contains('action-btn')) {
    document.getElementById('about-overlay').classList.remove('open');
  }
}

</script>
</body>
</html>
